<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vibrant Colorful Calculator</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(45deg, #ff007f, #7f00ff, #00f0ff);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .calculator {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 25px;
            border-radius: 25px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            width: 340px;
        }

        .display {
            width: 100%;
            height: 80px;
            background: rgba(0, 0, 0, 0.2);
            border: none;
            outline: none;
            border-radius: 15px;
            margin-bottom: 20px;
            color: #fff;
            font-size: 2rem;
            text-align: right;
            padding: 0 20px;
            box-shadow: inset 0 4px 10px rgba(0, 0, 0, 0.3);
        }

        .buttons {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }

        button {
            padding: 20px;
            border-radius: 15px;
            border: none;
            outline: none;
            font-size: 1.3rem;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
        }

        button:active {
            transform: scale(0.95);
        }

        /* Distinct Color Coding for Functions */
        .number {
            background: linear-gradient(135deg, #ff416c, #ff4b2b); /* Bright Coral/Red */
        }

        .operator {
            background: linear-gradient(135deg, #00c6ff, #0072ff); /* Electric Blue */
        }

        .clear {
            background: linear-gradient(135deg, #f857a6, #ff5858); /* Magenta/Pink */
        }

        .delete {
            background: linear-gradient(135deg, #f12711, #f5af19); /* Sunset Orange/Yellow */
        }

        .equal {
            grid-column: span 2;
            background: linear-gradient(135deg, #11998e, #38ef7d); /* Neon Mint Green */
            font-size: 1.6rem;
        }

        /* Hover effects to make it feel alive */
        button:hover {
            filter: brightness(1.2);
            box-shadow: 0 6px 15px rgba(255, 255, 255, 0.2);
        }
    </style>
</head>
<body>

    <div class="calculator">
        <input type="text" class="display" id="screen" readonly value="0">

        <div class="buttons">
            <button class="clear" onclick="clearScreen()">C</button>
            <button class="delete" onclick="deleteLast()">DEL</button>
            <button class="operator" onclick="appendValue('%')">%</button>
            <button class="operator" onclick="appendValue('/')">/</button>

            <button class="number" onclick="appendValue('7')">7</button>
            <button class="number" onclick="appendValue('8')">8</button>
            <button class="number" onclick="appendValue('9')">9</button>
            <button class="operator" onclick="appendValue('*')">&times;</button>

            <button class="number" onclick="appendValue('4')">4</button>
            <button class="number" onclick="appendValue('5')">5</button>
            <button class="number" onclick="appendValue('6')">6</button>
            <button class="operator" onclick="appendValue('-')">-</button>

            <button class="number" onclick="appendValue('1')">1</button>
            <button class="number" onclick="appendValue('2')">2</button>
            <button class="number" onclick="appendValue('3')">3</button>
            <button class="operator" onclick="appendValue('+')">+</button>

            <button class="number" onclick="appendValue('0')">0</button>
            <button class="number" onclick="appendValue('.')">.</button>
            <button class="equal" onclick="calculate()">=</button>
        </div>
    </div>

    <script>
        const screen = document.getElementById('screen');

        function appendValue(value) {
            if (screen.value === '0' && value !== '.') {
                screen.value = value;
            } else {
                screen.value += value;
            }
        }

        function clearScreen() {
            screen.value = '0';
        }

        function deleteLast() {
            if (screen.value.length > 1) {
                screen.value = screen.value.slice(0, -1);
            } else {
                screen.value = '0';
            }
        }

        function calculate() {
            try {
                // Using Function instead of eval for safer execution
                let result = new Function('return ' + screen.value)();
                
                // Handle decimals nicely
                if (result % 1 !== 0) {
                    result = parseFloat(result.toFixed(4));
                }
                
                screen.value = result;
            } catch (error) {
                screen.value = 'Error';
                setTimeout(clearScreen, 1500); // Reset after 1.5 seconds if error
            }
        }
    </script>
</body>
</html>
