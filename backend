const express = require('express');
const cors = require('cors');

const app = express();
const PORT = 5000;

// Middleware
app.use(cors()); // Allows your frontend to talk to this backend
app.use(express.json()); // Allows the server to parse JSON payloads

// Temporary in-memory database for calculation history
let calculationHistory = [];

/**
 * POST /api/calculate
 * Receives an expression from the frontend, evaluates it, and stores the history.
 */
app.post('/api/calculate', (req, res) => {
    const { expression } = req.body;

    if (!expression) {
        return res.status(400).json({ error: 'Expression is required' });
    }

    try {
        // Sanitize the expression to only allow math characters (Security guardrail)
        const sanitizedExpression = expression.replace(/[^0-9+\-*/().%\s]/g, '');
        
        // Evaluate the sanitized math expression safely
        const result = new Function(`return ${sanitizedExpression}`)();

        const calculation = {
            expression: sanitizedExpression,
            result: result,
            timestamp: new Date().toLocaleTimeString()
        };

        // Keep only the last 10 calculations
        calculationHistory.unshift(calculation);
        if (calculationHistory.length > 10) calculationHistory.pop();

        res.json({ success: true, result });
    } catch (error) {
        res.status(400).json({ error: 'Invalid mathematical expression' });
    }
});

/**
 * GET /api/history
 * Returns the latest history of calculations
 */
app.get('/api/history', (req, res) => {
    res.json(calculationHistory);
});

// Start Server
app.listen(PORT, () => {
    console.log(`🚀 Calculator Backend running on http://localhost:${PORT}`);
});
